{
  "name": "mcp-arxiv-server",
  "version": "1.0.0",
  "description": "MCP server for searching and analyzing arXiv research papers",
  "type": "module",
  "bin": {
    "mcp-arxiv-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "test": "npm run build && node --test test/**/*.test.mjs"
  },
  "keywords": ["mcp", "arxiv", "research", "papers", "ai"],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-xml-parser": "^4.3.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.3.0"
  }
}
